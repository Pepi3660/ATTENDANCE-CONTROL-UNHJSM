@page "{id:int}"
@model AttendanceControl.Web.Pages.Careers.EditModel

@{
    ViewData["Title"] = "Editar carrera";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Editar carrera</h2>
            <p class="text-muted mb-0">Actualiza la información de la carrera académica.</p>
        </div>
        <a asp-page="Index" class="btn btn-outline-secondary">Volver</a>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="alert alert-warning">@Model.Message</div>
    }

    <form method="post">
        <input type="hidden" asp-for="CareerId" />

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">Datos de la carrera</div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label">Nombre de carrera</label>
                        <input asp-for="CareerName" class="form-control" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Estado</label>
                        <select asp-for="IsActive" class="form-select">
                            <option value="true">Activa</option>
                            <option value="false">Inactiva</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2">
            <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
            <button type="submit" class="btn btn-primary">Guardar cambios</button>
        </div>
    </form>
</div>
