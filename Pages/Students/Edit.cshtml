@page "{id:int}"
@model AttendanceControl.Web.Pages.Students.EditModel

@{
    ViewData["Title"] = "Edit Student";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Editar Estudiante</h2>
            <p class="text-muted mb-0">
                Actualiza datos personales, documento, contacto y grupo oficial.
            </p>
        </div>

        <a asp-page="Index" class="btn btn-outline-secondary">
            Volver
        </a>
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-warning">
            @Model.Message
        </div>
    }

    <form method="post">

        <input type="hidden" asp-for="StudentId" />

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                Datos personales
            </div>

            <div class="card-body">
                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label">Primer nombre</label>
                        <input asp-for="FirstName" class="form-control" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Segundo nombre</label>
                        <input asp-for="SecondName" class="form-control" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Primer apellido</label>
                        <input asp-for="LastName" class="form-control" required />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Segundo apellido</label>
                        <input asp-for="SecondSurName" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Género</label>
                        <select asp-for="Gender" class="form-select">
                            <option value="M">Masculino</option>
                            <option value="F">Femenino</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Estado</label>
                        <select asp-for="IsActive" class="form-select">
                            <option value="true">Activo</option>
                            <option value="false">Inactivo</option>
                        </select>
                    </div>

                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white">
                Documento y contacto
            </div>

            <div class="card-body">
                <div class="row g-3">

                    <div class="col-md-4">
                        <label class="form-label">Tipo documento</label>
                        <select asp-for="DocumentTypeId"
                                asp-items="Model.DocumentTypes"
                                class="form-select">
                            <option value="">Seleccione</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Documento</label>
                        <input asp-for="Document" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Compañía telefónica</label>
                        <select asp-for="TelephoneCompanyId"
                                asp-items="Model.TelephoneCompanies"
                                class="form-select">
                            <option value="">Seleccione</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Teléfono</label>
                        <input asp-for="Phone" class="form-control" />
                    </div>

                    <div class="col-md-8">
                        <label class="form-label">Correo</label>
                        <input asp-for="Email" class="form-control" />
                    </div>

                </div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-secondary text-white">
                Grupo académico
            </div>

            <div class="card-body">
                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label">Grupo oficial</label>
                        <select asp-for="GroupId"
                                asp-items="Model.Groups"
                                class="form-select">
                            <option value="">Sin grupo</option>
                        </select>
                    </div>

                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-2">
            <a asp-page="Index" class="btn btn-outline-secondary">
                Cancelar
            </a>

            <button type="submit" class="btn btn-primary">
                Guardar cambios
            </button>
        </div>

    </form>

</div>